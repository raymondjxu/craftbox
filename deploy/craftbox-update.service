[Unit]
Description=Craftbox Minecraft Server Update (Instance: {{INSTANCE}})
Documentation=https://github.com/raymondjxu/craftbox
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=oneshot
Environment="CRAFTBOX_DIR={{CRAFTBOX_DIR}}"
Environment="LOG_LEVEL=info"
ExecStart={{CRAFTBOX_DIR}}/craftbox-update.sh
User=root
StandardOutput=journal
StandardError=journal
SyslogIdentifier=craftbox-update-{{INSTANCE}}

[Install]
WantedBy=multi-user.target
